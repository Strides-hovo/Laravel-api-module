{
  "name": "strides/laravel-api-module",
  "description": "A code generation toolkit for building clean, scalable Laravel APIs with modular architecture.",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "modules",
    "laravel",
    "strides",
    "module"
  ],
  "authors": [
    {
      "name": "Strides-hovo",
      "email": "strides@internet.ru",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Strides\\Module\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Strides\\Module\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "larastan/larastan": "^2.11",
    "laravel/pint": "^1.13",
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Strides\\Module\\Providers\\ModuleServiceProvider"
      ],
      "aliases": {
        "Module": "Strides\\Module\\Facades\\Module"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit tests",
    "test:unit": "vendor/bin/phpunit tests/Unit",
    "test:feature": "vendor/bin/phpunit tests/Feature",
    "pint": "vendor/bin/pint",
    "pint:test": "vendor/bin/pint --test",
    "analyse": "phpstan analyse --memory-limit=1G"
  },
  "config": {
    "sort-packages": true
  }
}
